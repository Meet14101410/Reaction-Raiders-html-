body {
    font-family: Arial, sans-serif;
    text-align: center;
    background: #e8f5e9;
}

h1 {
    color: #2e7d32;
}

button {
    padding: 10px 20px;
    margin: 5px;
    border: none;
    background: #43a047;
    color: white;
    cursor: pointer;
    border-radius: 5px;
}

button:hover {
    background: #2e7d32;
}

#result {
    font-size: 20px;
    margin-top: 15px;
}
